.env
.env.local
.env.*.local
*.pem

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# OS generated
.DS_Store

# Vercel CLI cache
.vercel

# Build artifacts
.turbo/
.cache/
