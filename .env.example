# ╔══════════════════════════════════════════════════════════════════════╗
# ║  CONTOH SAHAJA — Salin ke .env dan isi nilai sebenar.               ║
# ║  Semua nilai WAJIB diisi di Vercel Environment Variables.           ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Turso Database ───────────────────────────────────────────────────
# Dapatkan dari Turso Dashboard > Database > Tokens
TURSO_URL=libsql://NAMA_DB-NAMA_USER.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ─── GitHub Configuration ────────────────────────────────────────────
# Personal Access Token (https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=NAMA_OWNER_GITHUB/NAMA_REPO
GITHUB_WORKFLOW_ID=build.yml

# ─── Telegram Bot ─────────────────────────────────────────────────────
# Token dari @BotFather (https://t.me/BotFather)
# Username bot akan diambil terus dari Telegram guna token ni, tak perlu isi manual.
BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz

# ─── Build Workflow (required by BUILDER-APKV3's .github/workflows/build.yml) ──
# Tanpa 3 nilai ni, GitHub akan REJECT workflow_dispatch (422) — fail akan
# tetap ter-push ke temp/ tapi build TIDAK akan start, walaupun app tunjuk
# "berjaya". Wajib diisi.
#
# CHANNEL_ID: ID channel Telegram untuk broadcast status build (contoh: -1002371139452)
CHANNEL_ID=-1000000000000
# API_ID / API_HASH: daftar di https://my.telegram.org > API Development Tools
# (diperlukan oleh worker.py untuk Telethon — upload fail besar > had Bot API)
API_ID=00000000
API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
